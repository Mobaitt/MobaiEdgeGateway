{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "WebSocket": {
    "Path": "/ws",
    "HeartbeatIntervalSeconds": 30,
    "ReconnectIntervalSeconds": 5
  },
  "GatewayOptions": {
    "Collection": {
      "AggregateWindowMs": 1000,
      "DataExpirationSeconds": 30,
      "DefaultPollingIntervalMs": 1000,
      "MinPollingIntervalMs": 100,
      "MaxPollingIntervalMs": 60000
    },
    "Send": {
      "ChannelCacheExpirationSeconds": 30,
      "HttpTimeoutMs": 5000,
      "MqttQoS": 1,
      "MaxConcurrentChannels": 10
    },
    "Rules": {
      "CacheExpirationMinutes": 5
    },
    "VirtualNodes": {
      "CalculationCacheMs": 500,
      "MaxConcurrentCalculations": 20
    },
    "Database": {
      "Type": "SQLite",
      "ConnectionString": "Data Source=gateway.db",
      "InitializationMode": "Auto",
      "SeedMode": "Demo",
      "EnableSensitiveDataLogging": false
    }
  }
}
